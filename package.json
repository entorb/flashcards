{
  "name": "@flashcards/monorepo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.2.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build:1x1": "pnpm --filter 1x1 build",
    "build:div": "pnpm --filter div build",
    "build:eta": "pnpm --filter eta build",
    "build:lwk": "pnpm --filter lwk build",
    "build:pum": "pnpm --filter pum build",
    "build:voc": "pnpm --filter voc build",
    "build": "pnpm --filter \"./apps/*\" build",
    "check": "run-p format lint types spell test",
    "clean:cache": "rm -rf .cache apps/*/.cache packages/*/.cache coverage apps/*/coverage packages/*/coverage",
    "clean": "rm -rf node_modules apps/*/node_modules packages/*/node_modules apps/*/dist packages/*/dist",
    "cy:open:1x1": "pnpm --filter 1x1 cy:open",
    "cy:open:div": "pnpm --filter div cy:open",
    "cy:open:eta": "pnpm --filter eta cy:open",
    "cy:open:lwk": "pnpm --filter lwk cy:open",
    "cy:open:pum": "pnpm --filter pum cy:open",
    "cy:open:voc": "pnpm --filter voc cy:open",
    "cy:run:1x1": "pnpm --filter 1x1 cy:run",
    "cy:run:div": "pnpm --filter div cy:run",
    "cy:run:eta": "pnpm --filter eta cy:run",
    "cy:run:lwk": "pnpm --filter lwk cy:run",
    "cy:run:pum": "pnpm --filter pum cy:run",
    "cy:run:voc": "pnpm --filter voc cy:run",
    "cy:run": "pnpm --filter \"./apps/*\" cy:run",
    "dev:1x1": "pnpm --filter 1x1 dev",
    "dev:div": "pnpm --filter div dev",
    "dev:eta": "pnpm --filter eta dev",
    "dev:lwk": "pnpm --filter lwk dev",
    "dev:pum": "pnpm --filter pum dev",
    "dev:voc": "pnpm --filter voc dev",
    "dev": "pnpm --filter \"./apps/*\" --parallel dev",
    "find-unused": "node ./scripts/find-unused.js",
    "format": "biome check --write .",
    "lint": "eslint . --cache --cache-location .cache/eslintcache --cache-strategy content --fix",
    "preview": "pnpm --filter \"./apps/*\" --parallel preview",
    "preview:1x1": "pnpm --filter 1x1 preview",
    "preview:div": "pnpm --filter div preview",
    "preview:eta": "pnpm --filter eta preview",
    "preview:lwk": "pnpm --filter lwk preview",
    "preview:pum": "pnpm --filter pum preview",
    "preview:voc": "pnpm --filter voc preview",
    "spell": "cspell --cache --quiet \"**/*.{txt,md,html,js,ts,vue,json,yml,py}\"",
    "test:cov": "pnpm --filter \"./apps/*\" --filter \"./packages/*\" test:cov",
    "test": "pnpm --filter \"./apps/*\" --filter \"./packages/*\" test",
    "types": "pnpm --filter \"./apps/*\" --filter \"./packages/*\" types",
    "knip": "knip"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@quasar/vite-plugin": "^1.11.0",
    "@types/node": "^25.9.1",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^4.1.7",
    "@vue/compiler-dom": "^3.5.34",
    "@vue/test-utils": "^2.4.10",
    "cspell": "^10.0.0",
    "cypress": "^15.16.0",
    "esbuild": "^0.28.0",
    "eslint": "^10.4.0",
    "eslint-plugin-cypress": "^6.4.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-sonarjs": "^4.0.3",
    "eslint-plugin-vue": "^10.9.1",
    "eslint-plugin-vuejs-accessibility": "^2.5.0",
    "globals": "^17.6.0",
    "jiti": "^2.7.0",
    "jsdom": "^29.1.1",
    "knip": "^6.14.1",
    "npm-run-all2": "^9.0.0",
    "sass": "^1.99.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.13",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.7",
    "vue-eslint-parser": "^10.4.0",
    "vue-router": "^5.0.7",
    "vue-tsc": "^3.3.1"
  }
}
