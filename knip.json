{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "tags": ["-lintignore"],
  "ignore": ["**/route-map.d.ts"],
  "workspaces": {
    ".": {
      "entry": ["scripts/*.sh"]
    },
    "apps/*": {
      "project": ["src/**/*.ts", "src/**/*.vue", "!src/**/*.spec.ts"]
    },
    "packages/*": {
      "project": ["src/**/*.ts", "src/**/*.vue", "!src/**/*.spec.ts"]
    }
  }
}
